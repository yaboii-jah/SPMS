// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
} 

datasource db {
  provider = "mysql"
}

model users {
  user_id                   Int      @id @default(autoincrement())
  first_name                String   @db.VarChar(45)
  last_name                 String   @db.VarChar(45)
  middle_name               String?  @db.VarChar(45)
  department                String   @db.VarChar(45)
  supervisor_division_chief String   @db.VarChar(45)
  office_director           String   @db.VarChar(45)
  username                  String   @unique(map: "username_UNIQUE") @db.VarChar(100)
  created_at                DateTime @default(now()) @db.DateTime(0)
  password                  String   @db.VarChar(100)
}



